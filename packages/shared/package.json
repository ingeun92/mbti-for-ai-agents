{
  "name": "@mbti/shared",
  "version": "0.3.0",
  "type": "module",
  "description": "Shared types, questions, and scoring logic for MBTI AI Agent Test",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
